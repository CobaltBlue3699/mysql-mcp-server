# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=test_db

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# MCP Transport
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_SERVER_NAME=mysql-mcp-server
MCP_SERVER_VERSION=1.0.0

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Security Modes
DRY_RUN=false

# Permission Control (all false by default except SELECT and VIEW)
ALLOW_SELECT=true
ALLOW_VIEW=true
ALLOW_INSERT=false
ALLOW_UPDATE=false
ALLOW_DELETE=false
ALLOW_DDL=false